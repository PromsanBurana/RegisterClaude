# PostgreSQL connection string from Railway (auto-injected when you link a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Optional: protects GET /api/registrations admin endpoint
# Pick a long random string and set it on Railway as well
ADMIN_TOKEN=change-me-to-a-long-random-string

# Server port (Railway sets this automatically)
PORT=3000

# Set to "development" for local concurrent dev (vite + tsx watch)
NODE_ENV=development
