# ─── Storage ────────────────────────────────────────────────
# Path to the JSON file storing registrations.
# Mount this onto a Railway Volume.
REGISTRATION_DATA_PATH=/data/registrations.json

# Fallback: directory used when REGISTRATION_DATA_PATH is unset.
# Will store registrations.json + users.json inside this dir.
DATA_DIR=/data

# Path to the users JSON file (login accounts).
# If unset, defaults to <DATA_DIR>/users.json
USERS_DATA_PATH=/data/users.json

# ─── Auth ───────────────────────────────────────────────────
# Long random string used to sign session cookies (HMAC).
# Generate one with: openssl rand -hex 32
# IMPORTANT: must be set in production — otherwise sessions
# get invalidated on every restart.
SESSION_SECRET=replace-with-a-long-random-hex-string

# ─── Server ─────────────────────────────────────────────────
# Server port (Railway sets this automatically in production)
PORT=3000

# "development" runs vite + tsx watch in parallel.
# Otherwise the server serves dist/ + API together.
NODE_ENV=development
