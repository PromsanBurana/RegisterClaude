# Path to the JSON file storing registrations.
# Mounts directly to a Railway Volume — point this at the volume path.
REGISTRATION_DATA_PATH=/data/registrations.json

# Fallback: directory used when REGISTRATION_DATA_PATH is unset.
# DATA_DIR + /registrations.json
DATA_DIR=/data

# Server port (Railway injects this automatically in production)
PORT=3000

# "development" runs vite + tsx watch in parallel
# Otherwise the server serves dist/ + API together
NODE_ENV=development
