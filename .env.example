# Path to mounted volume directory.
# On Railway: ตั้ง Volume mount path เป็น /data ใน Service → Settings → Volumes
# Local dev: ปล่อยว่างได้ ระบบจะใช้ ./data อัตโนมัติ
DATA_DIR=/data

# Token สำหรับ GET /api/registrations (admin endpoint)
# ใช้ string ยาว ๆ สุ่ม เช่น `openssl rand -hex 32`
ADMIN_TOKEN=change-me-to-a-long-random-string

# Server port (Railway ใส่ให้เองตอน deploy)
PORT=3000

# "development" สำหรับรัน local แบบ vite + tsx watch แยก process
# "production" หรือไม่ตั้ง = serve dist/ + API ใน process เดียว
NODE_ENV=development
